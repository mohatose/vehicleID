            <Pane prefHeight="43.0" prefWidth="94.0" />
            <Button fx:id="searchbtn" onAction="#handleSearch" prefHeight="38.0" prefWidth="113.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Search">
